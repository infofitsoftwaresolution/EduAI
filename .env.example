# true for local development; false in production
ALLOW_LOCALHOST_CORS=true


PUBLIC_APP_URL=replace_with_public_app_url
FRONTEND_ORIGINS=replace_with_frontend_origins

VITE_API_BASE_URL=/backend

OPENAI_API_KEY=replace_with_openai_api_key
LLM_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

VECTOR_COLLECTION_NAME=replace_with_vector_collection_name
ELASTICSEARCH_INDEX_NAME=replace_with_elasticsearch_index_name
ES_JAVA_OPTS=-Xms512m -Xmx512m

POSTGRES_DB=replace_with_postgres_db
POSTGRES_USER=replace_with_postgres_user
POSTGRES_PASSWORD=replace_with_postgres_password

JWT_SECRET=replace_with_jwt_secret
ADMIN_EMAIL=replace_with_admin_email
ADMIN_PASSWORD=replace_with_admin_password.