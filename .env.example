HUGGINGFACEHUB_API_TOKEN=hf_xxx_replace_with_new_token
HF_HOME=D:/Cache/huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
CHROMA_PERSIST_DIR=./chroma_db
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated frontend domains allowed by backend CORS
FRONTEND_ORIGINS=https://lms.client.com,https://app.client.com

# true for local development; false in production
ALLOW_LOCALHOST_CORS=true
