HUGGINGFACEHUB_API_TOKEN=hf_xxx_replace_with_new_token
HF_HOME=D:/Cache/huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Comma-separated browser origins allowed to call this API (required for Vercel → Render).
# Example: http://localhost:5173,https://your-app.vercel.app
FRONTEND_ORIGINS=http://localhost:5173

# true for local development; false in production
ALLOW_LOCALHOST_CORS=true

# Auth (change JWT_SECRET in production)
JWT_SECRET=replace-with-long-random-secret
ADMIN_EMAIL=admin@eduai.local
ADMIN_PASSWORD=EduAI_Admin_2026
