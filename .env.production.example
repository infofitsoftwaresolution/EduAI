# Copy this file on the EC2 server as .env.production.
# Do not commit the real .env.production file.

# Public URL that users open in the browser.
# First EC2 test can be http://EC2_PUBLIC_IP
# Later, change it to https://your-domain.com
PUBLIC_APP_URL=http://your-ec2-public-ip
FRONTEND_ORIGINS=http://your-ec2-public-ip

# The frontend will call the backend through nginx at /backend.
VITE_API_BASE_URL=/backend

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
LLM_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Elasticsearch index for chunks, embeddings, and source metadata.
VECTOR_COLLECTION_NAME=replace_with_vector_collection_name
ELASTICSEARCH_INDEX_NAME=replace_with_elasticsearch_index_name
ES_JAVA_OPTS=-Xms1g -Xmx1g

# PostgreSQL app database. Use a stronger password in production.
POSTGRES_DB=replace_with_postgres_db
POSTGRES_USER=replace_with_postgres_user
POSTGRES_PASSWORD=replace_with_strong_db_password

# Auth. Use strong values in production.
JWT_SECRET=replace_with_long_random_jwt_secret
ADMIN_EMAIL=replace_with_admin_email
ADMIN_PASSWORD=replace_with_strong_admin_password
