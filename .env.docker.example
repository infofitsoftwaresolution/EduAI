# If you do not already have a .env file, copy this file to .env before running Docker Compose locally:
#   cp .env.docker.example .env
#
# Docker Compose reads .env automatically for ${...} values in docker-compose.yml.

OPENAI_API_KEY=sk-your-openai-key
LLM_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_COLLECTION_NAME=replace_with_vector_collection_name
ELASTICSEARCH_INDEX_NAME=replace_with_elasticsearch_index_name
EMBEDDING_DIMENSIONS=1536

JWT_SECRET=replace-with-local-random-secret
ADMIN_EMAIL=replace_with_admin_email
ADMIN_PASSWORD=replace_with_admin_password
