# If you do not already have a .env file, copy this file to .env before running Docker Compose locally:
#   cp .env.docker.example .env
#
# Docker Compose reads .env automatically for ${...} values in docker-compose.yml.

OPENAI_API_KEY=sk-your-openai-key
LLM_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_COLLECTION_NAME=rag_knowledge_base_openai
ELASTICSEARCH_INDEX_NAME=rag_knowledge_base_openai
EMBEDDING_DIMENSIONS=1536

JWT_SECRET=replace-with-local-random-secret
ADMIN_EMAIL=admin@eduai.local
ADMIN_PASSWORD=EduAI_Admin_2026
